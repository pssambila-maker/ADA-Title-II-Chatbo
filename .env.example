# LLM Provider: "github" (free, local dev) or "azure" (Azure OpenAI)
LLM_PROVIDER=github

# GitHub Models (free tier — get token from https://github.com/settings/tokens)
GITHUB_MODELS_TOKEN=ghp_your_token_here
GITHUB_MODELS_MODEL=gpt-4o-mini

# Azure OpenAI (swap to this for Azure deployment)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Bot Framework (leave empty for local Bot Emulator testing)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=MultiTenant

# Cost Controls
MAX_OUTPUT_TOKENS=500
MAX_TURNS_BEFORE_SUMMARY=8
RATE_LIMIT_PER_USER=10
